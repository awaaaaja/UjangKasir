<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="PrimaryGreenColor">#16A34A</Color>
    <Color x:Key="DarkNavyColor">#0F172A</Color>
    <Color x:Key="BackgroundColor">#F8FAFC</Color>
    <Color x:Key="WhiteCardColor">#FFFFFF</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="MutedTextColor">#64748B</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>

    <SolidColorBrush x:Key="PrimaryGreenBrush" Color="{StaticResource PrimaryGreenColor}"/>
    <SolidColorBrush x:Key="DarkNavyBrush" Color="{StaticResource DarkNavyColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="WhiteCardBrush" Color="{StaticResource WhiteCardColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WhiteCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
    </Style>
</ResourceDictionary>
