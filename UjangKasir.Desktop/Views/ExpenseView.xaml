<UserControl x:Class="UjangKasir.Desktop.Views.ExpenseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <DatePicker SelectedDate="{Binding FromDate}" Width="140" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="140" Margin="0,0,8,0"/>
                <TextBox Text="{Binding CategoryFilter, UpdateSourceTrigger=PropertyChanged}" Width="180" Margin="0,0,8,0"/>
                <Button Content="Filter" Command="{Binding LoadCommand}" Padding="14,8" Margin="0,0,8,0"/>
                <TextBlock Text="Total:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <TextBlock Text="{Binding TotalExpenseLabel}" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardBorderStyle}">
                <DataGrid ItemsSource="{Binding Expenses}" SelectedItem="{Binding SelectedExpense}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tanggal" Binding="{Binding ExpenseDate, StringFormat=dd/MM/yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="140"/>
                        <DataGridTextColumn Header="Nominal" Binding="{Binding Amount, StringFormat=N0}" Width="110"/>
                        <DataGridTextColumn Header="Metode" Binding="{Binding PaymentMethod}" Width="110"/>
                        <DataGridTextColumn Header="Keterangan" Binding="{Binding Description}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Form Pengeluaran" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                    <TextBlock Text="Tanggal"/>
                    <DatePicker SelectedDate="{Binding SelectedExpense.ExpenseDate}" Margin="0,4,0,8"/>
                    <TextBlock Text="Kategori"/>
                    <TextBox Text="{Binding SelectedExpense.Category, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                    <TextBlock Text="Nominal"/>
                    <TextBox Text="{Binding SelectedExpense.Amount, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                    <TextBlock Text="Metode Bayar"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedExpense.PaymentMethod}" Margin="0,4,0,8"/>
                    <TextBlock Text="Keterangan"/>
                    <TextBox Text="{Binding SelectedExpense.Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" Margin="0,4,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Baru" Command="{Binding NewCommand}" Padding="14,8" Margin="0,0,8,0"/>
                        <Button Content="Simpan" Command="{Binding SaveCommand}" Padding="14,8" Margin="0,0,8,0"/>
                        <Button Content="Hapus" Command="{Binding DeleteCommand}" Padding="14,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
