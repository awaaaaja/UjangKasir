<UserControl x:Class="UjangKasir.Desktop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <StackPanel Width="260">
                    <TextBlock Text="Stok Hampir Habis" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding LowStockProducts.Count}" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Width="260">
                    <TextBlock Text="Riwayat Movement" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding StockMovements.Count}" FontSize="30" FontWeight="Bold"/>
                </StackPanel>
                <Button Content="Refresh" Command="{Binding LoadCommand}" Padding="16,8" Height="38" VerticalAlignment="Bottom"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="16,0,0,0" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Produk Stok Hampir Habis" FontSize="20" FontWeight="SemiBold"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding LowStockProducts}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="100"/>
                            <DataGridTextColumn Header="Produk" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Stok" Binding="{Binding Stock, StringFormat=N2}" Width="80"/>
                            <DataGridTextColumn Header="Minimum" Binding="{Binding MinimumStock, StringFormat=N2}" Width="90"/>
                            <DataGridTextColumn Header="Satuan" Binding="{Binding Unit.Symbol}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1" Text="Tidak ada stok kritis." Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LowStockProducts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Kartu Stok / Stock Movement" FontSize="20" FontWeight="SemiBold"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding StockMovements}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tanggal" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="135"/>
                            <DataGridTextColumn Header="Produk" Binding="{Binding Product.Name}" Width="2*"/>
                            <DataGridTextColumn Header="Jenis" Binding="{Binding MovementType}" Width="90"/>
                            <DataGridTextColumn Header="Perubahan" Binding="{Binding QuantityChange, StringFormat=N2}" Width="90"/>
                            <DataGridTextColumn Header="Sebelum" Binding="{Binding QuantityBefore, StringFormat=N2}" Width="80"/>
                            <DataGridTextColumn Header="Sesudah" Binding="{Binding QuantityAfter, StringFormat=N2}" Width="80"/>
                            <DataGridTextColumn Header="User" Binding="{Binding User.FullName}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1" Text="Belum ada pergerakan stok." Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StockMovements.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
