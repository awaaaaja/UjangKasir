<UserControl x:Class="UjangKasir.Desktop.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:UjangKasir.Desktop.Helpers">
    <UserControl.InputBindings>
        <KeyBinding Key="F1" Command="{Binding FocusBarcodeCommand}"/>
        <KeyBinding Key="F2" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Key="F8" Command="{Binding PayCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding RemoveSelectedItemCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelDialogCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Scan Barcode"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,12,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                         helpers:FocusHelper.IsFocused="{Binding IsBarcodeFocused, Mode=TwoWay}"
                         Height="42"
                         FontSize="20"
                         VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding AddBarcodeCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Grid.Column="3"
                           Text="Cari Produk"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,12,0"/>
                <TextBox Grid.Column="4"
                         Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                         helpers:FocusHelper.IsFocused="{Binding IsSearchFocused, Mode=TwoWay}"
                         Height="42"
                         FontSize="16"
                         VerticalContentAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Produk Cepat"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="  F2 cari"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding QuickProducts}"
                              SelectedItem="{Binding SelectedQuickProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,14,0,0">
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding AddProductToCartCommand}"
                                          CommandParameter="{Binding SelectedQuickProduct}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="100"/>
                            <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Harga" Binding="{Binding SellingPrice, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Stok" Binding="{Binding Stock, StringFormat=N2}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1"
                               Text="Produk cepat kosong. Tambahkan produk aktif atau ubah pencarian."
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuickProducts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Keranjang"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ItemCountLabel}"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="320"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CartItems}"
                              SelectedItem="{Binding SelectedCartItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Margin="0,14,0,14">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produk" Binding="{Binding ProductName}" Width="2*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Harga" Binding="{Binding UnitPrice, StringFormat=N0}" IsReadOnly="True" Width="95"/>
                            <DataGridTextColumn Header="Diskon" Binding="{Binding Discount, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="90"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N0}" IsReadOnly="True" Width="110"/>
                            <DataGridTemplateColumn Header="Aksi" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="-"
                                                    Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="32"
                                                    Margin="0,0,4,0"/>
                                            <Button Content="+"
                                                    Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="32"
                                                    Margin="0,0,4,0"/>
                                            <Button Content="X"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="32"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1"
                               Text="Keranjang masih kosong. Scan barcode atau pilih produk cepat."
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CartItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="Clear Cart"
                                    Command="{Binding ClearCartCommand}"
                                    Padding="14,8"
                                    Margin="0,0,8,0"/>
                            <Button Content="Hold"
                                    Command="{Binding HoldTransactionCommand}"
                                    Padding="14,8"
                                    Margin="0,0,8,0"/>
                            <Button Content="Resume"
                                     Command="{Binding ResumeTransactionCommand}"
                                     Padding="14,8"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Member"/>
                            <TextBox Text="{Binding MemberSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30"
                                     Margin="0,4,0,4"/>
                            <ComboBox ItemsSource="{Binding MemberResults}"
                                      SelectedItem="{Binding SelectedMember}"
                                      DisplayMemberPath="Name"
                                      Height="32"
                                      Margin="0,0,0,8"/>

                            <TextBlock Text="Kode Promo"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="72"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding PromoCode, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32"/>
                                <Button Grid.Column="1"
                                        Content="Pakai"
                                        Command="{Binding ApplyPromoCommand}"
                                        Margin="6,0,0,0"/>
                            </Grid>

                            <TextBlock Text="Transaksi Hold"/>
                            <ComboBox ItemsSource="{Binding HeldTransactions}"
                                      SelectedItem="{Binding SelectedHeldTransaction}"
                                      DisplayMemberPath="HoldNumber"
                                      Height="32"
                                      Margin="0,4,0,8"/>

                            <TextBlock Text="TOTAL"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalLabel}"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryGreenBrush}"
                                       HorizontalAlignment="Right"/>

                            <TextBlock Text="Uang Bayar"/>
                            <ComboBox ItemsSource="{Binding PaymentMethods}"
                                      SelectedItem="{Binding SelectedPaymentMethod}"
                                      Height="34"
                                      Margin="0,4,0,8"/>
                            <TextBox Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="22"
                                     Height="40"
                                     HorizontalContentAlignment="Right"
                                     Margin="0,4,0,8"/>

                             <Grid Margin="0,0,0,12">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="*"/>
                                     <ColumnDefinition Width="Auto"/>
                                 </Grid.ColumnDefinitions>
                                 <StackPanel>
                                     <TextBlock Text="Diskon Promo"/>
                                     <TextBlock Text="Kembalian"
                                            FontWeight="SemiBold"/>
                                 </StackPanel>
                                 <StackPanel Grid.Column="1">
                                     <TextBlock Text="{Binding PromoDiscountLabel}"
                                                HorizontalAlignment="Right"/>
                                 <TextBlock Grid.Column="1"
                                            Text="{Binding ChangeAmountLabel}"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Right"/>
                                 </StackPanel>
                             </Grid>

                            <Button Content="BAYAR (F8)"
                                    Command="{Binding PayCommand}"
                                    Height="58"
                                    FontSize="22"
                                    FontWeight="Bold"
                                    Background="{StaticResource PrimaryGreenBrush}"
                                    Foreground="White"
                                    BorderThickness="0"/>
                            <Button Content="Cetak Struk"
                                    Command="{Binding PrintReceiptCommand}"
                                    Padding="14,8"
                                    Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding CheckoutSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
