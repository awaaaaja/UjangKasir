<UserControl x:Class="UjangKasir.Desktop.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="14">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="36"
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             ToolTip="Cari nama, kode, atau barcode"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding FilterCategory}"
                              DisplayMemberPath="Name"
                              Height="36"
                              Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding ActiveFilterOptions}"
                              SelectedItem="{Binding SelectedActiveFilter}"
                              Height="36"
                              Margin="0,0,10,0"/>
                    <Button Grid.Column="3"
                            Content="Cari"
                            Command="{Binding LoadProductsCommand}"
                            Padding="16,8"
                            Margin="0,0,8,0"/>
                    <Button Grid.Column="4"
                            Content="Reset"
                            Command="{Binding ResetFilterCommand}"
                            Padding="16,8"/>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Simulasi Scan"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding ScanBarcodeText, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             VerticalContentAlignment="Center"
                             ToolTip="Input scanner USB atau ketik barcode manual"/>
                    <Button Grid.Column="2"
                            Content="Cari Barcode"
                            Command="{Binding ScanBarcodeCommand}"
                            Padding="14,7"
                            Margin="10,0"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding ScanResultMessage}"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Daftar Produk" FontSize="20" FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,14,0,14">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="110"/>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="130"/>
                            <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Kategori" Binding="{Binding Category.Name}" Width="120"/>
                            <DataGridTextColumn Header="Harga Jual" Binding="{Binding SellingPrice, StringFormat=N0}" Width="110"/>
                            <DataGridTextColumn Header="Stok" Binding="{Binding Stock, StringFormat=N2}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1"
                               Text="Belum ada produk untuk filter ini."
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Products.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="Tambah"
                                Command="{Binding NewProductCommand}"
                                Padding="16,8"
                                Margin="0,0,8,0"/>
                        <Button Content="Edit"
                                Command="{Binding EditSelectedProductCommand}"
                                Padding="16,8"
                                Margin="0,0,8,0"/>
                        <Button Content="Nonaktifkan"
                                Command="{Binding DeactivateSelectedProductCommand}"
                                Padding="16,8"
                                Background="{StaticResource DangerBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0,0,8,0"/>
                        <Button Content="Generate Barcode"
                                Command="{Binding GenerateBarcodeCommand}"
                                Padding="16,8"
                                Margin="0,0,8,0"/>
                        <Button Content="Generate QR Code"
                                Command="{Binding GenerateQrCodeCommand}"
                                Padding="16,8"
                                Margin="0,0,8,0"/>
                        <Button Content="Preview Barcode"
                                Command="{Binding PreviewBarcodeCommand}"
                                Padding="16,8"
                                Margin="0,0,8,0"/>
                        <Button Content="Print Label Barcode"
                                Command="{Binding PrintLabelBarcodeCommand}"
                                Padding="16,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Form Produk" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryGreenBrush}" TextWrapping="Wrap" Margin="0,8,0,12"/>

                            <TextBlock Text="Kode"/>
                            <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>

                            <TextBlock Text="Barcode"/>
                            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" MinHeight="78">
                                    <StackPanel>
                                        <TextBlock Text="Preview Barcode" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Image Source="{Binding BarcodePreviewPath}" Height="64" Stretch="Uniform" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="QR" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <Image Source="{Binding QrCodePreviewPath}" Height="84" Width="84" Stretch="Uniform" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="{Binding LabelPreviewPath}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="Nama Produk"/>
                            <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>

                            <TextBlock Text="Kategori"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name" Margin="0,4,0,10"/>

                            <TextBlock Text="Satuan"/>
                            <ComboBox ItemsSource="{Binding Units}" SelectedItem="{Binding SelectedUnit}" DisplayMemberPath="Name" Margin="0,4,0,10"/>

                            <TextBlock Text="Supplier"/>
                            <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Margin="0,4,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Harga Beli"/>
                                    <TextBox Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Harga Jual"/>
                                    <TextBox Text="{Binding SellingPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Stok"/>
                                    <TextBox Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Minimum Stok"/>
                                    <TextBox Text="{Binding MinimumStock, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Expired Date"/>
                            <DatePicker SelectedDate="{Binding ExpiredDate}" Margin="0,4,0,10"/>

                            <CheckBox Content="Produk aktif" IsChecked="{Binding ProductIsActive}" Margin="0,0,0,12"/>

                            <Button Content="Simpan Produk"
                                    Command="{Binding SaveProductCommand}"
                                    Background="{StaticResource PrimaryGreenBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Height="40"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,16,0,0">
                        <TabControl>
                            <TabItem Header="Kategori">
                                <StackPanel Margin="0,12,0,0">
                                    <DataGrid ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedMasterCategory}" AutoGenerateColumns="False" Height="130" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="*"/>
                                            <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBox Text="{Binding SelectedMasterCategory.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,8"/>
                                    <CheckBox Content="Aktif" IsChecked="{Binding SelectedMasterCategory.IsActive}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Tambah" Command="{Binding NewCategoryCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Simpan" Command="{Binding SaveCategoryCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Nonaktif" Command="{Binding DeactivateCategoryCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Satuan">
                                <StackPanel Margin="0,12,0,0">
                                    <DataGrid ItemsSource="{Binding Units}" SelectedItem="{Binding SelectedMasterUnit}" AutoGenerateColumns="False" Height="130" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="Simbol" Binding="{Binding Symbol}" Width="90"/>
                                            <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBox Text="{Binding SelectedMasterUnit.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,8"/>
                                    <TextBox Text="{Binding SelectedMasterUnit.Symbol, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Aktif" IsChecked="{Binding SelectedMasterUnit.IsActive}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Tambah" Command="{Binding NewUnitCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Simpan" Command="{Binding SaveUnitCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Nonaktif" Command="{Binding DeactivateUnitCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Supplier">
                                <StackPanel Margin="0,12,0,0">
                                    <DataGrid ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedMasterSupplier}" AutoGenerateColumns="False" Height="130" IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="Telepon" Binding="{Binding Phone}" Width="120"/>
                                            <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBox Text="{Binding SelectedMasterSupplier.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,8"/>
                                    <TextBox Text="{Binding SelectedMasterSupplier.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding SelectedMasterSupplier.Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Aktif" IsChecked="{Binding SelectedMasterSupplier.IsActive}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Tambah" Command="{Binding NewSupplierCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Simpan" Command="{Binding SaveSupplierCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Nonaktif" Command="{Binding DeactivateSupplierCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
