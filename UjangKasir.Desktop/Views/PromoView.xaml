<UserControl x:Class="UjangKasir.Desktop.Views.PromoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.45*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>
        <Border Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,0,12"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Promos}" SelectedItem="{Binding SelectedPromo}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kode" Binding="{Binding Code}" Width="90"/>
                        <DataGridTextColumn Header="Nama" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="Tipe" Binding="{Binding PromoType}" Width="140"/>
                        <DataGridTextColumn Header="Diskon" Binding="{Binding DiscountValue, StringFormat=N0}" Width="90"/>
                        <DataGridTextColumn Header="Mulai" Binding="{Binding StartDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Akhir" Binding="{Binding EndDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Form Promo" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                <TextBlock Text="Kode"/>
                <TextBox Text="{Binding SelectedPromo.Code, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                <TextBlock Text="Nama"/>
                <TextBox Text="{Binding SelectedPromo.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                <TextBlock Text="Promo Type"/>
                <ComboBox ItemsSource="{Binding PromoTypes}" SelectedItem="{Binding SelectedPromo.PromoType}" Margin="0,4,0,8"/>
                <TextBlock Text="Discount Type"/>
                <ComboBox ItemsSource="{Binding DiscountTypes}" SelectedItem="{Binding SelectedPromo.DiscountType}" Margin="0,4,0,8"/>
                <TextBlock Text="Nilai Diskon"/>
                <TextBox Text="{Binding SelectedPromo.DiscountValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                <TextBlock Text="Minimum Belanja"/>
                <TextBox Text="{Binding SelectedPromo.MinimumPurchase, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                <TextBlock Text="Tanggal Mulai"/>
                <DatePicker SelectedDate="{Binding SelectedPromo.StartDate}" Margin="0,4,0,8"/>
                <TextBlock Text="Tanggal Akhir"/>
                <DatePicker SelectedDate="{Binding SelectedPromo.EndDate}" Margin="0,4,0,8"/>
                <CheckBox Content="Aktif" IsChecked="{Binding SelectedPromo.IsActive}" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Baru" Command="{Binding NewCommand}" Padding="14,8" Margin="0,0,8,0"/>
                    <Button Content="Simpan" Command="{Binding SaveCommand}" Padding="14,8" Margin="0,0,8,0"/>
                    <Button Content="Nonaktif" Command="{Binding DeactivateCommand}" Padding="14,8"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
