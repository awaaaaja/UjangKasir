<UserControl x:Class="UjangKasir.Desktop.Views.PurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="3" Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <Button Grid.Column="4" Content="Tambah Item" Command="{Binding AddLineCommand}" Padding="14,8"/>
                <ComboBox Grid.Column="5" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name" Margin="8,0,0,0"/>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Item Pembelian" FontSize="20" FontWeight="SemiBold"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Lines}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,12,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produk" Binding="{Binding ProductName}" IsReadOnly="True" Width="2*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            <DataGridTextColumn Header="Harga" Binding="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N0}" IsReadOnly="True" Width="120"/>
                            <DataGridTemplateColumn Header="Aksi" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Hapus" Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TotalLabel}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryGreenBrush}" HorizontalAlignment="Right"/>
                        <TextBlock Text="Dibayar"/>
                        <TextBox Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged}" Height="34" HorizontalContentAlignment="Right" Margin="0,4,0,8"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="55" AcceptsReturn="True" Margin="0,0,0,8"/>
                        <Button Content="Simpan Pembelian" Command="{Binding SaveCommand}" Height="44"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Riwayat Pembelian" FontSize="20" FontWeight="SemiBold"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Purchases}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nomor" Binding="{Binding PurchaseNumber}" Width="140"/>
                            <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.Name}" Width="140"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding PaymentStatus}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
