<UserControl x:Class="UjangKasir.Desktop.Views.ShiftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Buka Shift" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ActiveShiftLabel}" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,14"/>

                    <TextBlock Text="Modal awal"/>
                    <TextBox Text="{Binding OpeningCashInput, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,6,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Buka Shift"
                                Command="{Binding OpenShiftCommand}"
                                Padding="16,8"
                                Background="{StaticResource PrimaryGreenBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0,0,8,0"/>
                        <Button Content="Refresh"
                                Command="{Binding RefreshSummaryCommand}"
                                Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Tutup Shift" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Input uang aktual kasir. Selisih dihitung dari modal awal + penjualan cash." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,14"/>

                    <TextBlock Text="Uang aktual"/>
                    <TextBox Text="{Binding ClosingCashInput, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,6,0,12"/>

                    <Button Content="Tutup Shift"
                            Command="{Binding CloseShiftCommand}"
                            Padding="16,8"
                            Background="{StaticResource DangerBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.85*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Riwayat Shift" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Content="Cetak Laporan"
                                Command="{Binding PrintShiftReportCommand}"
                                Padding="14,8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RecentShifts}"
                              SelectedItem="{Binding SelectedShiftSummary}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,14,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kasir" Binding="{Binding CashierName}" Width="160"/>
                            <DataGridTextColumn Header="Buka" Binding="{Binding OpenedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                            <DataGridTextColumn Header="Tutup" Binding="{Binding ClosedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                            <DataGridTextColumn Header="Cash" Binding="{Binding CashSales, StringFormat=N0}" Width="95"/>
                            <DataGridTextColumn Header="Non Cash" Binding="{Binding NonCashSales, StringFormat=N0}" Width="95"/>
                            <DataGridTextColumn Header="Aktual" Binding="{Binding ClosingCash, StringFormat=N0}" Width="95"/>
                            <DataGridTextColumn Header="Selisih" Binding="{Binding CashDifference, StringFormat=N0}" Width="95"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1"
                               Text="Belum ada riwayat shift."
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentShifts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Preview Laporan Shift" FontSize="20" FontWeight="SemiBold"/>
                    <TextBox Grid.Row="1"
                             Text="{Binding ShiftReportText, Mode=OneWay}"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
